{
  "scene": "fix",
  "model": {
    "default_name": "mimo-v2.5-pro-plan",
    "allowed_names": [
      "mimo-v2.5-pro",
      "mimo-v2.5-pro-plan",
      "mimo-v2.5-pro-plan-sg",
      "deepseek-v4-flash",
      "deepseek-v4-pro",
      "qwen-plus",
      "ollama",
      "gpt-5.4",
      "claude-sonnet-4-6",
      "gemini-2.5-flash"
    ],
    "temperature_profile": "write"
  },
  "runtime": {
    "agent": {
      "max_iterations": 12
    },
    "runner": {
      "tool_timeout_seconds": 90.0
    }
  },
  "version": "v1",
  "description": "占位符补强场景",
  "extends": [],
  "tool_selection": {
    "mode": "select",
    "tool_tags_any": [
      "fins",
      "web"
    ]
  },
  "defaults": {
    "missing_fragment_policy": "error"
  },
  "fragments": [
    {
      "id": "base_agents",
      "type": "AGENTS",
      "path": "base/agents.md",
      "required": true,
      "order": 100
    },
    {
      "id": "base_soul",
      "type": "SOUL",
      "path": "base/soul.md",
      "required": true,
      "order": 200
    },
    {
      "id": "base_fact_rules",
      "type": "SOUL",
      "path": "base/fact_rules.md",
      "required": true,
      "order": 300
    },
    {
      "id": "base_tools",
      "type": "TOOLS",
      "path": "base/tools.md",
      "required": true,
      "order": 400
    },
    {
      "id": "fix_scene",
      "type": "SCENE",
      "path": "scenes/fix.md",
      "required": true,
      "order": 500
    }
  ],
  "context_slots": [
    "fins_default_subject",
    "base_user"
  ]
}
