{
  "scene": "infer",
  "model": {
    "default_name": "mimo-v2.5-pro-thinking-plan",
    "allowed_names": [
      "mimo-v2.5-pro-thinking",
      "mimo-v2.5-pro-thinking-plan",
      "mimo-v2.5-pro-thinking-plan-sg",
      "deepseek-v4-flash-thinking",
      "deepseek-v4-pro-thinking",
      "qwen-plus-thinking",
      "ollama",
      "gpt-5.4-thinking",
      "claude-sonnet-4-6-thinking",
      "gemini-2.5-flash-thinking"
    ],
    "temperature_profile": "infer"
  },
  "runtime": {
    "agent": {
      "max_iterations": 12
    },
    "runner": {
      "tool_timeout_seconds": 90.0
    }
  },
  "version": "v1",
  "description": "公司业务类型与关键约束判断场景",
  "extends": [],
  "tool_selection": {
    "mode": "select",
    "tool_tags_any": [
      "fins"
    ]
  },
  "defaults": {
    "missing_fragment_policy": "error"
  },
  "fragments": [
    {
      "id": "base_agents",
      "type": "AGENTS",
      "path": "base/agents.md",
      "required": true,
      "order": 100
    },
    {
      "id": "base_tools",
      "type": "TOOLS",
      "path": "base/tools.md",
      "required": true,
      "order": 400
    },
    {
      "id": "infer_scene",
      "type": "SCENE",
      "path": "scenes/infer.md",
      "required": true,
      "order": 500
    }
  ],
  "context_slots": [
    "fins_default_subject"
  ]
}
